{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "value": "prod"
    },
    "location": {
      "value": "eastasia"
    },
    "uniqueSuffix": {
      "value": "abc01"
    },
    "tenantId": {
      "value": "<YOUR-TENANT-ID>"
    },
    "spClientId": {
      "value": "<YOUR-SERVICE-PRINCIPAL-CLIENT-ID>"
    },
    "spClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<BOOTSTRAP-SUB-ID>/resourceGroups/<BOOTSTRAP-RG>/providers/Microsoft.KeyVault/vaults/<BOOTSTRAP-KV-NAME>"
        },
        "secretName": "sp-client-secret"
      }
    },
    "anthropicApiKey": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<BOOTSTRAP-SUB-ID>/resourceGroups/<BOOTSTRAP-RG>/providers/Microsoft.KeyVault/vaults/<BOOTSTRAP-KV-NAME>"
        },
        "secretName": "anthropic-api-key"
      }
    },
    "monitoredSubscriptionId": {
      "value": "<YOUR-SUBSCRIPTION-ID>"
    },
    "deployerObjectId": {
      "value": "<YOUR-AAD-OBJECT-ID>"
    }
  }
}

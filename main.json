      "tags": "[variables('tags')]",
      "properties": {
        "description": "Fires when any VM CPU exceeds 85% for 5 minutes",
        "severity": 2,
        "enabled": true,
        "scopes": [
          "[format('/subscriptions/{0}', parameters('monitoredSubscriptionId'))]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "targetResourceType": "Microsoft.Compute/virtualMachines",
